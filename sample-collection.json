{
  "name": "Sample API",
  "variables": [
    { "key": "baseUrl", "value": "https://jsonplaceholder.typicode.com" }
  ],
  "requests": [
    {
      "id": "get-posts",
      "name": "Get Posts",
      "method": "GET",
      "url": "{{baseUrl}}/posts",
      "routeParams": [],
      "queryParams": [
        { "key": "_limit", "value": "5", "enabled": true }
      ],
      "headers": [],
      "body": null,
      "postRequestScript": null
    },
    {
      "id": "get-post",
      "name": "Get Post by ID",
      "method": "GET",
      "url": "{{baseUrl}}/posts/:id",
      "routeParams": [
        { "key": "id", "value": "1" }
      ],
      "queryParams": [],
      "headers": [],
      "body": null,
      "postRequestScript": "// Extract data from response\nconst json = bod.response.json();\nif (json.id) {\n  bod.environment.set('lastPostId', String(json.id));\n}"
    }
  ]
}
