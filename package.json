{
  "type": "module",
  "name": "bewareofdog",
  "version": "1.0.0",
  "description": "REST API Debugger",
  "author": "BewareOfDog contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/liamwhan/BewareOfDog.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "dist": "npm run build && npm run icons && electron-builder",
    "dist:dir": "npm run build && npm run icons && electron-builder --dir"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simple-git": "^3.33.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.0.0",
    "png2icons": "^2.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "build": {
    "appId": "com.bewareofdog.app",
    "productName": "BewareOfDog",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "public/bod.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
